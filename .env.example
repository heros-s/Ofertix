# ==============================================================================
# Ofertix — Exemplo de Variáveis de Ambiente
# Copie este arquivo como ".env" na raiz do projeto e preencha com seus valores.
# ⚠️  NUNCA faça commit do arquivo ".env" com valores reais.
# ==============================================================================

# ------------------------------------------------------------------------------
# Supabase — Compartilhado entre Frontend (NEXT_PUBLIC_*) e Backend
# Obtenha em: https://supabase.com/dashboard/project/<seu-projeto>/settings/api
# ------------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ------------------------------------------------------------------------------
# Asaas — Gateway de Pagamentos
# Sandbox: https://sandbox.asaas.com — Produção: https://app.asaas.com
# ------------------------------------------------------------------------------
ASAAS_API_KEY=
ASAAS_BASE_URL=https://api-sandbox.asaas.com/v3

# Defina como "true" para simular onboarding do Asaas sem conta real (desenvolvimento/MVP)
SIMULATE_ASAAS=true

# ------------------------------------------------------------------------------
# Cloudinary — Upload de Imagens dos Produtos
# Obtenha em: https://cloudinary.com/console
# ------------------------------------------------------------------------------
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# ------------------------------------------------------------------------------
# URLs da Aplicação
# ------------------------------------------------------------------------------
# URL pública do frontend (usado pelo Supabase OAuth callback)
NEXT_PUBLIC_SITE_URL=https://ofertixmarketplace.vercel.app

# URL do backend NestJS (usado pelo frontend para chamadas à API)
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001

# Porta do servidor NestJS (backend)
PORT=3001
